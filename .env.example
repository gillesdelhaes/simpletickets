# ── App ───────────────────────────────────────────────────────────────────────
APP_SECRET_KEY=change-me-to-a-long-random-string
APP_BASE_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/simplytickets
DB_PASSWORD=postgres

# ── Google OIDC (set up guide: docs/setup-google-oidc.md) ────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_WORKSPACE_DOMAIN=company.com

# ── Slack (set up guide: docs/setup-slack.md) ─────────────────────────────────
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
SLACK_APP_TOKEN=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=support@company.com

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_LOCAL_PATH=/data/attachments
ATTACHMENT_MAX_SIZE_MB=10

# ── Vertex AI / Gemini (Phase 3) ──────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json
GEMINI_MODEL=gemini-1.5-pro

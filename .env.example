# ══════════════════════════════════════════════════════════════════════════════
# SimplyTickets — Environment Variables
# Copy this file to .env and fill in your values before starting the stack.
# NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
APP_SECRET_KEY=change-me-to-a-long-random-string
# URL where the frontend is served — used for CORS and email reset links
APP_BASE_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# asyncpg driver URL — points to the 'db' service inside Docker
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/simplytickets
# Used by the postgres container to set the superuser password
DB_PASSWORD=postgres

# ── Google OIDC ───────────────────────────────────────────────────────────────
# Leave blank to disable Google SSO — local accounts only
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Restrict login to a specific Google Workspace domain (e.g. company.com)
# Leave blank to allow any Google account
GOOGLE_WORKSPACE_DOMAIN=

# ── Slack Integration ─────────────────────────────────────────────────────────
# Leave all blank to disable Slack features
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=
# Required for Socket Mode (bolt-python)
SLACK_APP_TOKEN=xapp-...
# Emoji reaction that triggers ticket creation (without colons, e.g. "ticket")
SLACK_TRIGGER_EMOJI=ticket
# Comma-separated channel IDs to monitor (e.g. C01234567,C09876543)
# Leave blank to monitor ALL channels
SLACK_MONITORED_CHANNELS=

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Leave SMTP_HOST blank to print emails to stdout (development mode)
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=support@company.com

# ── File Storage ──────────────────────────────────────────────────────────────
STORAGE_LOCAL_PATH=/data/attachments
ATTACHMENT_MAX_SIZE_MB=10

# ── Vertex AI / Gemini (Phase 3 — leave blank for now) ───────────────────────
GOOGLE_CLOUD_PROJECT=
GOOGLE_APPLICATION_CREDENTIALS=/secrets/gcp-sa.json
GEMINI_MODEL=gemini-1.5-pro
